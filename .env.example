# EXPO_PUBLIC_API_URL should be your backend address. 
# For testing on physical devices, replace localhost with your local network IP (e.g., http://192.168.1.100:8000) or an ngrok tunnel.
EXPO_PUBLIC_API_URL=http://localhost:8000

# LiveKit connection URL
EXPO_PUBLIC_LIVEKIT_URL=wss://your-livekit-url.livekit.cloud
